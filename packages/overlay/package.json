{
  "name": "@opencontroller/overlay",
  "version": "0.1.0",
  "description": "React and OBS-friendly controller overlays for OpenController.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SYMBaiEX/OpenController.git",
    "directory": "packages/overlay"
  },
  "keywords": [
    "controller",
    "gamepad",
    "overlay",
    "react",
    "obs",
    "opencontroller"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/ControllerOverlay.d.ts",
      "import": "./dist/react/ControllerOverlay.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@opencontroller/core": "^0.1.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0 || >=19.0.0",
    "react-dom": ">=18.0.0 || >=19.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.15",
    "@types/react": "^19.1.6",
    "typescript": "^5.8.3"
  }
}

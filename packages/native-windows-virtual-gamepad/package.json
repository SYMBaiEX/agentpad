{
  "name": "@opencontroller/native-windows-virtual-gamepad",
  "version": "0.1.0",
  "description": "Windows VHF/HID virtual gamepad helpers, XUSB compatibility helpers, and diagnostics for OpenController.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/SYMBaiEX/OpenController#readme",
  "bugs": {
    "url": "https://github.com/SYMBaiEX/OpenController/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SYMBaiEX/OpenController.git",
    "directory": "packages/native-windows-virtual-gamepad"
  },
  "keywords": [
    "ai",
    "controller",
    "gamepad",
    "windows",
    "vhf",
    "hid",
    "xinput",
    "xusb",
    "opencontroller"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./diagnostics": {
      "types": "./dist/diagnostics.d.ts",
      "import": "./dist/diagnostics.js"
    },
    "./vhf": {
      "types": "./dist/vhf.d.ts",
      "import": "./dist/vhf.js"
    },
    "./xusb": {
      "types": "./dist/xusb.d.ts",
      "import": "./dist/xusb.js"
    }
  },
  "bin": {
    "opencontroller-windows-gamepad-doctor": "dist/bin/doctor.js",
    "opencontroller-windows-vhf-assets": "dist/bin/vhf-assets.js",
    "opencontroller-windows-vhf-setup": "dist/bin/setup.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json && node ../../scripts/fix-esm-extensions.mjs dist && chmod +x dist/bin/*.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test src/__tests__"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@opencontroller/core": "^0.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.15",
    "typescript": "^5.8.3"
  }
}

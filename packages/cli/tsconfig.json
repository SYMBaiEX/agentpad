{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "baseUrl": "../..",
    "paths": {
      "@opencontroller/core": ["packages/core/src/index.ts"],
      "@opencontroller/core/*": ["packages/core/src/*"],
      "@opencontroller/overlay": ["packages/overlay/src/index.ts"],
      "@opencontroller/overlay/*": ["packages/overlay/src/*"]
    }
  },
  "include": ["src"],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../overlay"
    }
  ]
}

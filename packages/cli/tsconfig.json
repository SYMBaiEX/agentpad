{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "baseUrl": "../..",
    "paths": {
      "@opencontroller/core": ["packages/core/src/index.ts"],
      "@opencontroller/core/*": ["packages/core/src/*"],
      "@opencontroller/native-linux-uinput": [
        "packages/native-linux-uinput/src/index.ts"
      ],
      "@opencontroller/native-linux-uinput/*": [
        "packages/native-linux-uinput/src/*"
      ],
      "@opencontroller/native-macos-driverkit": [
        "packages/native-macos-driverkit/src/index.ts"
      ],
      "@opencontroller/native-macos-driverkit/*": [
        "packages/native-macos-driverkit/src/*"
      ],
      "@opencontroller/native-windows-virtual-gamepad": [
        "packages/native-windows-virtual-gamepad/src/index.ts"
      ],
      "@opencontroller/native-windows-virtual-gamepad/*": [
        "packages/native-windows-virtual-gamepad/src/*"
      ],
      "@opencontroller/overlay": ["packages/overlay/src/index.ts"],
      "@opencontroller/overlay/*": ["packages/overlay/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/__tests__/**", "src/**/*.test.ts"],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../native-linux-uinput"
    },
    {
      "path": "../native-macos-driverkit"
    },
    {
      "path": "../native-windows-virtual-gamepad"
    },
    {
      "path": "../overlay"
    }
  ]
}

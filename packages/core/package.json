{
  "name": "@opencontroller/core",
  "version": "0.1.8",
  "description": "Core OpenController controller runtime for AI-agent virtual controller control.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/SYMBaiEX/OpenController#readme",
  "bugs": {
    "url": "https://github.com/SYMBaiEX/OpenController/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SYMBaiEX/OpenController.git",
    "directory": "packages/core"
  },
  "keywords": ["ai", "controller", "gamepad", "opencontroller"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./profiles": {
      "types": "./dist/profiles/index.d.ts",
      "import": "./dist/profiles/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./actions": {
      "types": "./dist/actions/index.d.ts",
      "import": "./dist/actions/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge/index.d.ts",
      "import": "./dist/bridge/index.js"
    },
    "./hid": {
      "types": "./dist/hid/index.d.ts",
      "import": "./dist/hid/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json && node ../../scripts/fix-esm-extensions.mjs dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test src/__tests__/controller.test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.2.15",
    "typescript": "^5.8.3"
  }
}
